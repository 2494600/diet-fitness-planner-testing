<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Diet and Fitness Hybrid Framework Master Suite">


    <listeners>
        <listener class-name= "listeners.TestListener"/>
    </listeners>


    <test name="Cucumber BDD Feature Validations" preserve-order="true">
        <classes>
            <class name="tests.CucumberTestRunner"/>
        </classes>
    </test>

    <test name="Pure TestNG Infrastructure Smoke Checks" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.SmokeTestSuite"/>
        </classes>
    </test>

    <test name="Backend RestAssured API Layer Verifications" preserve-order="true">
        <classes>
            <class name="apitests.FitnessApiTests"/>
        </classes>
    </test>

</suite>